# â”€â”€ Required â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# LLM API key. For OpenAI: sk-...  For Azure OpenAI: your deployment key.
LLM_API_KEY=sk-your-key-here

# â”€â”€ Optional â€” defaults shown â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Full URL of the chat completions endpoint.
# OpenAI default: https://api.openai.com/v1/chat/completions
# Azure OpenAI:   https://<resource>.openai.azure.com/openai/deployments/<name>/chat/completions?api-version=2024-02-01
LLM_API_URL=https://api.openai.com/v1/chat/completions

# Model name passed in the request body.
LLM_MODEL=gpt-4o

# Maximum PDF upload size in megabytes (default 50).
MAX_FILE_SIZE_MB=50

# Estimated processing seconds per page used for ETA (default 17).
AVG_SECONDS_PER_PAGE=17

# Path to the Poppler bin/ directory if not on system PATH.
# Leave unset if Poppler is in playground/bin/ (auto-detected) or on PATH.
# Example (Windows): POPPLER_PATH=C:\tools\poppler\bin
# POPPLER_PATH=
